# Template only — do not commit real keys. Create the Secret imperatively:
#
#   kubectl create secret generic users-service-secrets \
#     --from-literal=RAILS_MASTER_KEY="$(cat service1/config/master.key)" \
#     -n microservices
#
apiVersion: v1
kind: Secret
metadata:
  name: users-service-secrets
  namespace: microservices
  labels:
    app: users-service
type: Opaque
stringData:
  RAILS_MASTER_KEY: replace-me
