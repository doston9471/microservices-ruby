# Template only — do not commit real keys. Create the Secret imperatively:
#
#   kubectl create secret generic products-service-secrets \
#     --from-literal=RAILS_MASTER_KEY="$(cat service2/config/master.key)" \
#     -n microservices
#
apiVersion: v1
kind: Secret
metadata:
  name: products-service-secrets
  namespace: microservices
  labels:
    app: products-service
type: Opaque
stringData:
  RAILS_MASTER_KEY: replace-me
